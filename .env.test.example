# Copy this file to .env.test and fill in real values.
# .env.test is in .gitignore — never commit it.

# ── Supabase ──────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon key (public, safe for browser)
SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — KEEP SECRET, only used in scripts/create-test-users.js
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Playwright base URL ───────────────────────────────────────────
BASE_URL=http://localhost:3000

# ── Test account credentials ──────────────────────────────────────
# These are created by:  node scripts/create-test-users.js
TEST_FREE_EMAIL=test-free@centa.app
TEST_FREE_PASS=TestPass123!

TEST_PRO_EMAIL=test-pro@centa.app
TEST_PRO_PASS=TestPass123!

TEST_LIFETIME_EMAIL=test-lifetime@centa.app
TEST_LIFETIME_PASS=TestPass123!
